# 灵境 APP - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===========================================
# 应用配置
# ===========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# 前端地址 (CORS 使用)
FRONTEND_URL=http://localhost:3001

# ===========================================
# 数据库 (PostgreSQL)
# ===========================================
# Railway 等平台使用 DATABASE_URL
DATABASE_URL=postgresql://lingjing:password@localhost:5432/lingjing

# 分别配置 (可选)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=lingjing
# DATABASE_PASSWORD=your_password_here
# DATABASE_NAME=lingjing

# ===========================================
# Redis
# ===========================================
# Railway 等平台使用 REDIS_URL
REDIS_URL=redis://localhost:6379

# 分别配置 (可选)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ===========================================
# JWT 认证
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# AI 服务 (OpenClaw)
# ===========================================
OPENCLAW_API_URL=http://localhost:18789
OPENCLAW_API_KEY=your_openclaw_api_key

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=debug

# ===========================================
# 上传配置
# ===========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB
